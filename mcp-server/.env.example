# GiriFlow MCP server — environment variables
# Copy to .env and fill in real values. Never commit .env.

# Supabase project URL (Settings → API in Supabase dashboard).
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Service-role key (Settings → API). Bypasses RLS — keep it secret.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
